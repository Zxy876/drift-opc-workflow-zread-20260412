[Unit]
Description=Drift Java Worker (%i)
After=drift-asyncaiflow.service
Wants=drift-asyncaiflow.service

[Service]
Type=simple
User=__STACK_USER__
EnvironmentFile=/etc/drift-stack.env
WorkingDirectory=/opt/drift-stack-systemd
ExecStart=/opt/drift-stack-systemd/bin/run-java-worker.sh %i
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target