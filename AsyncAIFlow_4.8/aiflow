def interactive_action_detail(runtime_url: str) -> None:
    print("\nAction Detail")
    print("-" * 40)
    action_id = prompt_int("Action ID: ")
    if action_id is None:
        print("Action ID is required.")
        return

    try:
        detail = fetch_action_execution(runtime_url, action_id)
    except CliError as exc:
        message = str(exc)
        if "HTTP 404" in message and "Action not found" in message:
            try:
                workflow_actions = fetch_workflow_actions(runtime_url, action_id)
            except CliError:
                raise

            print(
                f"Input {action_id} looks like a Workflow ID, not an Action ID."
            )
            print("Available Action IDs in that workflow:")
            print_action_id_table(workflow_actions)
            print("Please run Action Detail again with one of the ACTION_ID values above.")
            return
        raise

    print(f"Action ID : {detail.get('actionId')}")
    print(f"Workflow  : {detail.get('workflowId')}")
    print(f"Type      : {detail.get('type')}")
    print(f"Status    : {detail.get('status')}")
    print(f"Worker    : {detail.get('workerId')}")
    print(f"Started   : {detail.get('startedAt')}")
    print(f"Finished  : {detail.get('finishedAt')}")
    print(f"Error     : {detail.get('error')}")

    payload = detail.get("payload")
    if payload is not None:
        print("\nPayload")
        print("-" * 40)
        print(pretty_value(payload))

    result = detail.get("result")
    if result is not None:
        print("\nResult")
        print("-" * 40)
        print(pretty_value(result))

    logs = detail.get("logs")
    if isinstance(logs, list) and logs:
        print("\nLogs")
        print("-" * 40)
        for index, log_entry in enumerate(logs, start=1):
            if not isinstance(log_entry, dict):
                continue
            created_at = log_entry.get("createdAt")
            status = log_entry.get("status")
            worker_id = log_entry.get("workerId")
            print(f"{index}. {created_at} {status} worker={worker_id}")


