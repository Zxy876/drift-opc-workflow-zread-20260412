    return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="aiflow",
        description="AsyncAIFlow developer CLI",
    )

    subparsers = parser.add_subparsers(dest="command", required=True)

    init_parser = subparsers.add_parser("init", help="Initialize .aiflow config in current project")
    init_parser.set_defaults(handler=cmd_init)

    issue_parser = subparsers.add_parser("issue", help="Create a plan from a natural language issue")
    issue_parser.add_argument("issue", help="Natural language issue statement")
    issue_parser.add_argument("--repo-context", dest="repo_context", help="Optional repository context")
    issue_parser.add_argument("--file", help="Optional file path context")
    issue_parser.add_argument("--save", help="Save planner output to a plan file")
    issue_parser.add_argument("--edit", action="store_true", help="Open generated plan in $EDITOR")
    issue_parser.add_argument("--json", action="store_true", help="Print raw plan JSON")
    issue_parser.set_defaults(handler=cmd_issue)

    plan_parser = subparsers.add_parser("plan", help="Display a readable plan tree from a plan file")
    plan_parser.add_argument("plan_file", help="Path to plan JSON file")
    plan_parser.set_defaults(handler=cmd_plan)

    run_parser = subparsers.add_parser("run", help="Submit a plan file to runtime as workflow/actions")
    run_parser.add_argument("plan_file", help="Path to plan JSON file")
    run_parser.add_argument("--name", help="Workflow name override")
    run_parser.add_argument("--description", help="Workflow description override")
    run_parser.add_argument("--no-follow", action="store_true", help="Submit workflow only, without progress streaming")
    run_parser.add_argument("--no-summary", action="store_true", help="Do not fetch and print summary after run")
    run_parser.set_defaults(handler=cmd_run)

    status_parser = subparsers.add_parser("status", help="Query workflow status from runtime")
    status_parser.add_argument("--workflow-id", type=int, help="Workflow id to query")
    status_parser.add_argument("--json", action="store_true", help="Print status payload as JSON")
    status_parser.set_defaults(handler=cmd_status)

    summary_parser = subparsers.add_parser("summary", help="Show aggregated workflow summary")
    summary_parser.add_argument("--workflow-id", type=int, help="Workflow id to summarize")
    summary_parser.add_argument("--json", action="store_true", help="Print summary payload as JSON")
    summary_parser.set_defaults(handler=cmd_summary)

    interactive_parser = subparsers.add_parser("interactive", help="Start interactive ASCII workflow console")
    interactive_parser.set_defaults(handler=cmd_interactive)

    return parser


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)

    try:
        return int(args.handler(args))
    except CliError as exc:
        print(f"aiflow: {exc}", file=sys.stderr)
        return 2
    except KeyboardInterrupt:
        print("aiflow: interrupted", file=sys.stderr)
        return 130


if __name__ == "__main__":
    sys.exit(main())