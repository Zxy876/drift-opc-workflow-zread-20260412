#!/usr/bin/env python3
"""AsyncAIFlow developer CLI."""

from __future__ import annotations

import argparse
import datetime as dt
import json
import os
import pathlib
import shlex
import subprocess
import sys
import textwrap
import time
import urllib.error
import urllib.parse
import urllib.request
from typing import Any


CONFIG_DIR_NAME = ".aiflow"
CONFIG_FILE_NAME = "config.json"
LAST_PLAN_FILE_NAME = "last-plan.json"
LAST_RUN_FILE_NAME = "last-run.json"

DEFAULT_CONFIG = {
    "openai_api_key": "",
    "deepseek_api_key": "",
    "llm_base_url": "",
    "llm_endpoint": "",
    "llm_model": "",
    "llm_api_key": "",
    "runtime_url": "http://localhost:8080",
}

LOCAL_RUNTIME_HOSTS = {"localhost", "127.0.0.1", "::1", "0.0.0.0"}


class CliError(Exception):
    """Known command execution error."""


def current_timestamp() -> str:
    return dt.datetime.now().strftime("%Y%m%d-%H%M%S")


def find_initialized_root(start: pathlib.Path) -> pathlib.Path | None:
    for candidate in [start, *start.parents]:
        config_file = candidate / CONFIG_DIR_NAME / CONFIG_FILE_NAME
        if config_file.exists():
            return candidate
    return None


def require_initialized_root() -> pathlib.Path:
    root = find_initialized_root(pathlib.Path.cwd())
    if root is None:
        raise CliError("Project is not initialized. Run 'aiflow init' in your project root first.")
    return root


def read_json_file(path: pathlib.Path) -> dict[str, Any]:
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except FileNotFoundError as exc:
        raise CliError(f"File not found: {path}") from exc
    except json.JSONDecodeError as exc:
        raise CliError(f"Invalid JSON in {path}: {exc}") from exc


def write_json_file(path: pathlib.Path, payload: dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(payload, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")


def config_path(project_root: pathlib.Path) -> pathlib.Path:
    return project_root / CONFIG_DIR_NAME / CONFIG_FILE_NAME


def load_config(project_root: pathlib.Path) -> dict[str, Any]:
    config_file = project_root / CONFIG_DIR_NAME / CONFIG_FILE_NAME
    if not config_file.exists():
        raise CliError("Missing .aiflow/config.json. Run 'aiflow init' first.")

    loaded = read_json_file(config_file)
    merged = dict(DEFAULT_CONFIG)
    merged.update({k: v for k, v in loaded.items() if k in DEFAULT_CONFIG})
    return merged


def runtime_url_from_config(config: dict[str, Any]) -> str:
    value = str(config.get("runtime_url", "")).strip()
    if not value:
        raise CliError("runtime_url is empty in .aiflow/config.json")
    return value.rstrip("/")


def decode_body(raw: bytes) -> tuple[str, Any]:
    text = raw.decode("utf-8", errors="replace").strip()
    if not text:
        return "", None
    try:
        return text, json.loads(text)
    except json.JSONDecodeError:
        return text, text


def should_bypass_proxy(url: str) -> bool:
    try:
        host = (urllib.parse.urlsplit(url).hostname or "").lower()
    except ValueError:
        return False
    return host in LOCAL_RUNTIME_HOSTS


def open_http_request(request: urllib.request.Request, timeout_seconds: int):
    if should_bypass_proxy(request.full_url):
        opener = urllib.request.build_opener(urllib.request.ProxyHandler({}))
        return opener.open(request, timeout=timeout_seconds)
    return urllib.request.urlopen(request, timeout=timeout_seconds)


def http_json(
    method: str,
    url: str,
    payload: dict[str, Any] | None = None,
    *,
    timeout_seconds: int = 20,
    allow_http_error: bool = False,
) -> tuple[int, Any]:
    data = None
    headers = {"Accept": "application/json"}
    if payload is not None:
        data = json.dumps(payload, ensure_ascii=False).encode("utf-8")
        headers["Content-Type"] = "application/json"

    request = urllib.request.Request(url=url, data=data, headers=headers, method=method.upper())
    try:
        with open_http_request(request, timeout_seconds) as response:
            body_text, body_json = decode_body(response.read())
            _ = body_text
            return response.getcode(), body_json
    except urllib.error.HTTPError as exc:
        body_text, body_json = decode_body(exc.read())
        if allow_http_error:
            return exc.code, body_json
        raise CliError(f"HTTP {exc.code} for {url}: {body_text}") from exc
    except urllib.error.URLError as exc:
        raise CliError(f"Cannot reach runtime at {url}: {exc.reason}") from exc


def unwrap_api_response(body: Any) -> Any:
    if isinstance(body, dict) and {"success", "data"}.issubset(body.keys()):
        success = bool(body.get("success"))
        if not success:
            raise CliError(str(body.get("message") or "Runtime API returned failure"))
        return body.get("data")
    return body


def ensure_plan_array(plan_root: Any) -> list[dict[str, Any]]:
    if not isinstance(plan_root, dict):
        raise CliError("Invalid plan payload: root must be a JSON object")
    plan = plan_root.get("plan")
    if not isinstance(plan, list):
        raise CliError("Invalid plan payload: missing 'plan' array")
    for index, step in enumerate(plan):
        if not isinstance(step, dict):
            raise CliError(f"Invalid plan step at index {index}: must be object")
        step_type = step.get("type")
        if not isinstance(step_type, str) or not step_type.strip():
            raise CliError(f"Invalid plan step at index {index}: missing type")
        payload = step.get("payload")
        if payload is not None and not isinstance(payload, dict):
            raise CliError(f"Invalid plan step at index {index}: payload must be object")
        depends_on = step.get("depends_on", [])
        if not isinstance(depends_on, list) or not all(isinstance(v, int) for v in depends_on):
            raise CliError(f"Invalid plan step at index {index}: depends_on must be integer array")
    return plan


def print_plan_compact(plan: list[dict[str, Any]]) -> None:
    print("AsyncAIFlow Plan")
    print()
    for idx, step in enumerate(plan, start=1):
        print(f"{idx} {step.get('type', 'unknown')}")


def print_plan_tree(plan: list[dict[str, Any]]) -> None:
    print("AsyncAIFlow Plan")
    print()
    for idx, step in enumerate(plan, start=1):
        depends_on = step.get("depends_on") or []
        head = f"{idx}. {step.get('type', 'unknown')}"
        if depends_on:
            human = ", ".join(str(x + 1) for x in depends_on)
            head += f" <- depends on {human}"
        print(head)

        payload = step.get("payload") or {}
        detail = None
        for key in ("query", "issue", "focus", "module", "file"):
            value = payload.get(key)
            if isinstance(value, str) and value.strip():
                detail = f"   {key}: {value.strip()}"
                break
        if detail is None:
            detail = f"   schemaVersion: {payload.get('schemaVersion', 'n/a')}"
        print(detail)


def launch_editor(target_path: pathlib.Path) -> None:
    editor = os.environ.get("EDITOR", "vi").strip()
    if not editor:
        raise CliError("EDITOR is empty")

    try:
        command = shlex.split(editor)
    except ValueError as exc:
        raise CliError(f"Invalid EDITOR value '{editor}': {exc}") from exc

    if not command:
        raise CliError("EDITOR command is empty")

    result = subprocess.run(command + [str(target_path)])
    if result.returncode != 0:
        raise CliError(f"Editor exited with code {result.returncode}")


def last_plan_path(project_root: pathlib.Path) -> pathlib.Path:
    return project_root / CONFIG_DIR_NAME / LAST_PLAN_FILE_NAME


def last_run_path(project_root: pathlib.Path) -> pathlib.Path:
    return project_root / CONFIG_DIR_NAME / LAST_RUN_FILE_NAME


def cmd_init(_args: argparse.Namespace) -> int:
    project_root = pathlib.Path.cwd()
    aiflow_dir = project_root / CONFIG_DIR_NAME
    config_file = config_path(project_root)
    aiflow_dir.mkdir(parents=True, exist_ok=True)

    config = dict(DEFAULT_CONFIG)
    if config_file.exists():
        existing = read_json_file(config_file)
        if isinstance(existing, dict):
            config.update({k: v for k, v in existing.items() if k in DEFAULT_CONFIG})

    write_json_file(config_file, config)
    print(f"Initialized AsyncAIFlow config: {config_file}")
    return 0


def request_plan(
    runtime_url: str,
    issue: str,
    repo_context: str | None = None,
    file_path: str | None = None,
) -> dict[str, Any]:
    payload: dict[str, Any] = {"issue": issue}
    if repo_context:
        payload["repo_context"] = repo_context
    if file_path:
        payload["file"] = file_path

    _, response_body = http_json("POST", f"{runtime_url}/planner/plan", payload)
    response_data = unwrap_api_response(response_body)
    plan = ensure_plan_array(response_data)
    return {
        "issue": issue,
        "repo_context": repo_context or "",
        "file": file_path or "",
        "plan": plan,
    }


def cmd_issue(args: argparse.Namespace) -> int:
    project_root = require_initialized_root()
    config = load_config(project_root)
    runtime_url = runtime_url_from_config(config)
    plan_root = request_plan(runtime_url, args.issue, args.repo_context, args.file)
    plan = ensure_plan_array(plan_root)

    if args.json:
        print(json.dumps(plan_root, ensure_ascii=False, indent=2))
    else:
        print_plan_compact(plan)

    write_json_file(last_plan_path(project_root), plan_root)

    saved_path: pathlib.Path | None = None
    if args.save:
        saved_path = pathlib.Path(args.save).expanduser().resolve()
        write_json_file(saved_path, plan_root)
        print(f"\nSaved plan: {saved_path}")

    if args.edit:
        edit_path = saved_path if saved_path is not None else last_plan_path(project_root)
        launch_editor(edit_path)
        print(f"Edited plan: {edit_path}")

    return 0


def load_plan_file(path_arg: str) -> tuple[pathlib.Path, dict[str, Any], list[dict[str, Any]]]:
    plan_file = pathlib.Path(path_arg).expanduser().resolve()
    root = read_json_file(plan_file)
    plan = ensure_plan_array(root)
    return plan_file, root, plan


def cmd_plan(args: argparse.Namespace) -> int:
    _, _, plan = load_plan_file(args.plan_file)
    print_plan_tree(plan)
    return 0


def submit_plan_to_runtime(
    project_root: pathlib.Path,
    runtime_url: str,
    plan_file: pathlib.Path,
    plan: list[dict[str, Any]],
    workflow_name: str,
    workflow_description: str,
    *,
    show_submission_progress: bool,
) -> int:
    _, workflow_body = http_json(
        "POST",
        f"{runtime_url}/workflow/create",
        {
            "name": workflow_name,
            "description": workflow_description,
        },
    )
    workflow_data = unwrap_api_response(workflow_body)
    if not isinstance(workflow_data, dict) or "id" not in workflow_data:
        raise CliError("Runtime returned invalid workflow response")

    workflow_id = int(workflow_data["id"])
    if show_submission_progress:
        print("Running workflow")
        print(f"workflow_id: {workflow_id}")
        print()

    action_ids: list[int] = []
    step_runs: list[dict[str, Any]] = []

    for idx, step in enumerate(plan):
        step_type = str(step.get("type", "")).strip()
        payload = step.get("payload") or {}
        depends_on = step.get("depends_on") or []

        upstream_action_ids: list[int] = []
        for dep_index in depends_on:
            if dep_index < 0 or dep_index >= len(action_ids):
                raise CliError(
                    f"Plan dependency index out of range at step {idx + 1}: {dep_index}"
                )
            upstream_action_ids.append(action_ids[dep_index])

        action_payload_json = json.dumps(payload, ensure_ascii=False, separators=(",", ":"))
        action_request = {
            "workflowId": workflow_id,
            "type": step_type,
            "payload": action_payload_json,
            "upstreamActionIds": upstream_action_ids,
        }

        _, action_body = http_json("POST", f"{runtime_url}/action/create", action_request)
        action_data = unwrap_api_response(action_body)
        if not isinstance(action_data, dict) or "id" not in action_data:
            raise CliError(f"Runtime returned invalid action response for step {idx + 1}")

        action_id = int(action_data["id"])
        action_ids.append(action_id)

        if show_submission_progress:
            icon = "→" if idx == len(plan) - 1 else "✓"
            print(f"{icon} {step_type}")

        step_runs.append(
            {
                "index": idx,
                "type": step_type,
                "action_id": action_id,
                "upstream_action_ids": upstream_action_ids,
            }
        )

    run_record = {
        "created_at": dt.datetime.now().isoformat(timespec="seconds"),
        "runtime_url": runtime_url,
        "workflow_id": workflow_id,
        "workflow_name": workflow_name,
        "plan_file": str(plan_file),
        "steps": step_runs,
    }
    write_json_file(last_run_path(project_root), run_record)

    if show_submission_progress:
        print()
        print(f"Saved run metadata: {last_run_path(project_root)}")

    return workflow_id


def cmd_run(args: argparse.Namespace) -> int:
    project_root = require_initialized_root()
    config = load_config(project_root)
    runtime_url = runtime_url_from_config(config)

    plan_file, plan_root, plan = load_plan_file(args.plan_file)

    plan_issue = str(plan_root.get("issue") or "").strip()

    workflow_name = args.name or f"aiflow-run-{current_timestamp()}"
    workflow_description = args.description or plan_issue or f"Created by aiflow run from {plan_file.name}"

    workflow_id = submit_plan_to_runtime(
        project_root,
        runtime_url,
        plan_file,
        plan,
        workflow_name,
        workflow_description,
        show_submission_progress=True,
    )

    print()
    print(f"Workflow {workflow_id} started")
    print("-" * 40)

    if args.no_follow:
        print(f"Use 'aiflow status --workflow-id {workflow_id}' to follow progress.")
        if not args.no_summary:
            print(f"Use 'aiflow summary --workflow-id {workflow_id}' to view summary.")
        return 0

    final_status = stream_workflow_progress(runtime_url, workflow_id)

    if args.no_summary:
        return 0

    try:
        summary = fetch_workflow_summary(runtime_url, workflow_id)
    except CliError as exc:
        print()
        print(f"Summary unavailable for workflow {workflow_id}: {exc}")
        return 0

    print()
    if final_status == "TIMEOUT":
        print("Summary (workflow still running; partial view)")
        print("-" * 40)
    print_workflow_summary(summary)
    return 0


def fetch_workflow_execution(runtime_url: str, workflow_id: int) -> dict[str, Any]:
    endpoint = f"{runtime_url}/workflow/{urllib.parse.quote(str(workflow_id), safe='')}"
    _, body = http_json("GET", endpoint)
    data = unwrap_api_response(body)
    if not isinstance(data, dict):
        raise CliError(f"Runtime returned invalid workflow payload for workflow {workflow_id}")
    return data


def fetch_workflow_actions(runtime_url: str, workflow_id: int) -> list[dict[str, Any]]:
    endpoint = f"{runtime_url}/workflow/{urllib.parse.quote(str(workflow_id), safe='')}/actions"
    _, body = http_json("GET", endpoint)
    data = unwrap_api_response(body)
    if not isinstance(data, list) or not all(isinstance(item, dict) for item in data):
        raise CliError(f"Runtime returned invalid action list for workflow {workflow_id}")
    return data


def fetch_workflow_summary(runtime_url: str, workflow_id: int) -> dict[str, Any]:
    endpoint = f"{runtime_url}/workflow/{urllib.parse.quote(str(workflow_id), safe='')}/summary"
    _, body = http_json("GET", endpoint)
    data = unwrap_api_response(body)
    if not isinstance(data, dict):
        raise CliError(f"Runtime returned invalid workflow summary payload for workflow {workflow_id}")
    return data


def fetch_recent_workflows(runtime_url: str, limit: int = 1) -> list[dict[str, Any]]:
    endpoint = f"{runtime_url}/workflows?limit={max(1, limit)}"
    _, body = http_json("GET", endpoint)
    data = unwrap_api_response(body)
    if not isinstance(data, list) or not all(isinstance(item, dict) for item in data):
        raise CliError("Runtime returned invalid recent workflow payload")
    return data


def fetch_action_execution(runtime_url: str, action_id: int) -> dict[str, Any]:
    endpoint = f"{runtime_url}/action/{urllib.parse.quote(str(action_id), safe='')}"
    _, body = http_json("GET", endpoint)
    data = unwrap_api_response(body)
    if not isinstance(data, dict):
        raise CliError(f"Runtime returned invalid action payload for action {action_id}")
    return data


def action_status_icon(status: str) -> str:
    normalized = status.strip().upper()
    if normalized == "COMPLETED":
        return "✓"
    if normalized == "RUNNING":
        return "→"
    if normalized == "FAILED":
        return "✗"
    return "·"


def action_status_marker_ascii(status: str) -> str:
    normalized = status.strip().upper()
    if normalized == "COMPLETED":
        return "[OK]"
    if normalized == "RUNNING":
        return "[..]"
    if normalized == "FAILED":
        return "[X]"
    return "[ ]"


def parse_numeric_id(value: Any) -> int | None:
    if isinstance(value, int):
        return value
    if isinstance(value, str):
        stripped = value.strip()
        if stripped.isdigit():
            return int(stripped)
    return None


def load_last_run_record(project_root: pathlib.Path) -> dict[str, Any] | None:
    run_file = last_run_path(project_root)
    if not run_file.exists():
        return None

    record = read_json_file(run_file)
    return record if isinstance(record, dict) else None


def resolve_workflow_id(
    project_root: pathlib.Path,
    runtime_url: str,
    explicit_workflow_id: int | None,
) -> int | None:
    if explicit_workflow_id is not None:
        return explicit_workflow_id

    run_record = load_last_run_record(project_root)
    if isinstance(run_record, dict):
        raw_workflow_id = run_record.get("workflow_id")
        parsed = parse_numeric_id(raw_workflow_id)
        if parsed is not None:
            return parsed

    recent_workflows = fetch_recent_workflows(runtime_url, limit=1)
    if recent_workflows:
        parsed = parse_numeric_id(recent_workflows[0].get("workflowId"))
        if parsed is not None:
            return parsed

    return None


def workflow_progress(actions: list[dict[str, Any]]) -> tuple[int, int]:
    total = len(actions)
    completed = sum(1 for action in actions if str(action.get("status") or "").upper() == "COMPLETED")
    return completed, total


def print_workflow_action_lines(
    actions: list[dict[str, Any]],
    *,
    marker,
) -> None:
    for action in actions:
        step_type = str(action.get("type") or "unknown")
        status = str(action.get("status") or "PENDING")
        print(f"{marker(status)} {step_type}")


def stream_workflow_progress(
    runtime_url: str,
    workflow_id: int,
    *,
    poll_interval_seconds: float = 2.0,
    timeout_seconds: int = 300,
) -> str:
    start = time.monotonic()
    last_signature: tuple[Any, ...] | None = None

    while True:
        workflow_execution = fetch_workflow_execution(runtime_url, workflow_id)
        workflow_actions = fetch_workflow_actions(runtime_url, workflow_id)
        status = str(workflow_execution.get("status") or "RUNNING").upper()
        signature = (
            status,
            tuple(
                (
                    parse_numeric_id(action.get("actionId")),
                    str(action.get("status") or "PENDING"),
                )
                for action in workflow_actions
            ),
        )

        if signature != last_signature:
            print(f"Status: {status}")
            if not workflow_actions:
                print("(no actions)")
            else:
                completed, total = workflow_progress(workflow_actions)
                print(f"Progress {completed}/{total}")
                print()
                print_workflow_action_lines(workflow_actions, marker=action_status_marker_ascii)
            print()
            last_signature = signature

        if status in ("COMPLETED", "FAILED"):
            print(f"Workflow {workflow_id} {status.lower()}")
            return status

        if time.monotonic() - start >= timeout_seconds:
            print(f"Workflow {workflow_id} progress stream timed out after {timeout_seconds} seconds")
            return "TIMEOUT"

        time.sleep(max(0.5, poll_interval_seconds))


def prompt_input(prompt: str) -> str | None:
    try:
        return input(prompt)
    except EOFError:
        return None


def prompt_yes_no(prompt: str, *, default: bool = False) -> bool:
    while True:
        raw = prompt_input(prompt)
        if raw is None:
            return default
        normalized = raw.strip().lower()
        if not normalized:
            return default
        if normalized in ("y", "yes"):
            return True
        if normalized in ("n", "no"):
            return False
        print("Please enter y or n.")


def prompt_int(prompt: str, *, default: int | None = None) -> int | None:
    raw = prompt_input(prompt)
    if raw is None:
        return default
    normalized = raw.strip()
    if not normalized:
        return default
    if not normalized.isdigit():
        raise CliError(f"Invalid numeric value: {normalized}")
    return int(normalized)


def print_action_id_table(actions: list[dict[str, Any]]) -> None:
    if not actions:
        print("(no actions)")
        return

    print(f"{'ACTION_ID':<20} {'TYPE':<20} STATUS")
    print("-" * 72)
    for action in actions:
        action_id = str(action.get("actionId") or "?")
        step_type = str(action.get("type") or "unknown")
        status = str(action.get("status") or "UNKNOWN")
        print(f"{action_id:<20} {step_type:<20} {status}")


def pretty_value(value: Any) -> str:
    if isinstance(value, (dict, list)):
        return json.dumps(value, ensure_ascii=False, indent=2)
    if value is None:
        return "null"
    return str(value)


def format_duration_seconds(value: Any) -> str:
    if isinstance(value, (int, float)):
        seconds = int(value)
        if seconds < 60:
            return f"{seconds}s"
        minutes, remain = divmod(seconds, 60)
        if minutes < 60:
            return f"{minutes}m {remain}s"
        hours, remain_minutes = divmod(minutes, 60)
        return f"{hours}h {remain_minutes}m"
    return "n/a"


def print_wrapped_bullet_lines(items: list[Any], *, width: int = 96) -> None:
    for raw in items:
        line = str(raw or "").strip()
        if not line:
            continue
        wrapped = textwrap.wrap(line, width=max(40, width - 2)) or [line]
        print(f"- {wrapped[0]}")
        for continuation in wrapped[1:]:
            print(f"  {continuation}")


def resolve_context_quality(summary: dict[str, Any]) -> dict[str, Any]:
    context_quality = summary.get("contextQuality")
    if isinstance(context_quality, dict):
        return context_quality

    retrieval_total = 0
    source_total = 0
    noisy_action_count = 0
    has_retrieval = False
    has_source = False

    actions = summary.get("actions")
    if isinstance(actions, list):
        for action in actions:
            if not isinstance(action, dict):
                continue
            retrieval_count = action.get("retrievalCount")
            if isinstance(retrieval_count, int):
                retrieval_total += retrieval_count
                has_retrieval = True

            source_count = action.get("sourceCount")
            if isinstance(source_count, int):
                source_total += source_count
                has_source = True

            if action.get("noisyRetrieval") is True:
                noisy_action_count += 1

    quality: dict[str, Any] = {
        "noiseDetected": noisy_action_count > 0,
        "noisyActionCount": noisy_action_count,
    }
    if has_retrieval:
        quality["retrievalCount"] = retrieval_total
    if has_source:
        quality["sourceCount"] = source_total
    return quality


def print_workflow_summary(summary: dict[str, Any]) -> None:
    workflow_id = summary.get("workflowId")
    status = str(summary.get("status") or "UNKNOWN").upper()
    duration = format_duration_seconds(summary.get("durationSeconds"))
    issue = str(summary.get("issue") or "").strip()

    print("Workflow Summary")
    print("-" * 40)
    print(f"Workflow ID: {workflow_id}")
    print(f"Status     : {status}")
    print(f"Duration   : {duration}")
    if issue:
        print(f"Issue      : {issue}")

    context_quality = resolve_context_quality(summary)
    if isinstance(context_quality, dict):
        retrieval_count = context_quality.get("retrievalCount")
        source_count = context_quality.get("sourceCount")
        noise_detected = context_quality.get("noiseDetected") is True
        noise_summary = str(context_quality.get("noiseSummary") or "").strip()
        noisy_action_count = context_quality.get("noisyActionCount")

        if (
            isinstance(retrieval_count, int)
            or isinstance(source_count, int)
            or noise_detected
            or isinstance(noisy_action_count, int)
            or noise_summary
        ):
            print()
            print("Context Quality")
            print("-" * 40)
            if isinstance(retrieval_count, int):
                print(f"- retrievalCount: {retrieval_count}")
            if isinstance(source_count, int):
                print(f"- sourceCount: {source_count}")
            if isinstance(noisy_action_count, int) and noisy_action_count > 0:
                print(f"- noisyActions: {noisy_action_count}")
            if noise_detected:
                if noise_summary:
                    print(f"- noise: {noise_summary}")
                else:
                    print("- noise: dependency directories detected")
            elif noise_summary:
                print(f"- noise: {noise_summary}")
            else:
                print("- noise: none detected")

    plan = summary.get("plan")
    if isinstance(plan, list):
        print()
        print("Plan")
        print("-" * 40)
        if plan:
            for index, step in enumerate(plan, start=1):
                print(f"{index}. {step}")
        else:
            print("(no plan steps)")

    actions = summary.get("actions")
    if isinstance(actions, list):
        print()
        print("Results")
        print("-" * 40)
        if not actions:
            print("(no actions)")
        for action in actions:
            if not isinstance(action, dict):
                continue
            action_type = str(action.get("actionType") or "unknown")
            action_status = str(action.get("status") or "PENDING")
            print(f"{action_status_icon(action_status)} {action_type} ({action_status.upper()})")

            action_duration = format_duration_seconds(action.get("durationSeconds"))
            if action_duration != "n/a":
                print(f"  duration: {action_duration}")

            detail_items: list[str] = []
            if isinstance(action.get("matchCount"), int):
                detail_items.append(f"matches: {action.get('matchCount')}")
            if isinstance(action.get("sourceCount"), int):
                detail_items.append(f"sources: {action.get('sourceCount')}")
            if isinstance(action.get("retrievalCount"), int):
                detail_items.append(f"retrievalCount: {action.get('retrievalCount')}")
            if action.get("noisyRetrieval") is True:
                detail_items.append("noise: dependency dirs detected")
            if detail_items:
                print("  " + " | ".join(detail_items))

            short_result = str(action.get("shortResult") or "").strip()
            if short_result:
                wrapped_summary = textwrap.wrap(short_result, width=88) or [short_result]
                print(f"  summary: {wrapped_summary[0]}")
                for continuation in wrapped_summary[1:]:
                    print(f"           {continuation}")

    findings = summary.get("keyFindings")
    if isinstance(findings, list):
        print()
        print("Key Findings")
        print("-" * 40)
        if findings:
            print_wrapped_bullet_lines(findings)
        else:
            print("(none)")

    warnings = summary.get("warnings")
    if isinstance(warnings, list):
        print()
        print("Issues")
        print("-" * 40)
        if warnings:
            print_wrapped_bullet_lines(warnings)
        else:
            print("(none)")

    suggestions = summary.get("suggestions")
    if isinstance(suggestions, list):
        print()
        print("Suggestions")
        print("-" * 40)
        if suggestions:
            print_wrapped_bullet_lines(suggestions)
        else:
            print("(none)")


def mask_secret(value: str) -> str:
    if not value:
        return "(empty)"
    if len(value) <= 6:
        return "*" * len(value)
    return value[:3] + "..." + value[-3:]


def interactive_new_issue(project_root: pathlib.Path, runtime_url: str) -> None:
    print("\nNew Issue")
    print("-" * 40)

    issue_raw = prompt_input("Describe your issue: ")
    if issue_raw is None:
        return
    issue = issue_raw.strip()
    if not issue:
        print("Issue is required.")
        return

    repo_context = (prompt_input("Repo context (optional): ") or "").strip()
    file_path = (prompt_input("File path (optional): ") or "").strip()

    plan_root = request_plan(runtime_url, issue, repo_context or None, file_path or None)
    plan = ensure_plan_array(plan_root)
    write_json_file(last_plan_path(project_root), plan_root)

    print()
    print("Plan")
    print("-" * 40)
    print_plan_tree(plan)
    print()

    if not prompt_yes_no("Run this workflow now? [y/n]: ", default=True):
        return

    workflow_name = f"aiflow-interactive-{current_timestamp()}"
    workflow_id = submit_plan_to_runtime(
        project_root,
        runtime_url,
        last_plan_path(project_root),
        plan,
        workflow_name,
        issue,
        show_submission_progress=False,
    )

    print()
    print(f"Workflow {workflow_id} started")
    print("-" * 40)
    stream_workflow_progress(runtime_url, workflow_id)

    try:
        actions = fetch_workflow_actions(runtime_url, workflow_id)
    except CliError as exc:
        print(f"Cannot fetch action list for workflow {workflow_id}: {exc}")
        return

    print()
    print("Action IDs")
    print("-" * 40)
    print_action_id_table(actions)
    print("Use [5] Action Detail and enter an Action ID above.")


def interactive_recent_workflows(runtime_url: str) -> None:
    print("\nRecent Workflows")
    print("-" * 40)

    limit = prompt_int("Limit (default 10): ", default=10)
    if limit is None:
        limit = 10
    if limit < 1 or limit > 200:
        raise CliError("Limit must be between 1 and 200")
    workflows = fetch_recent_workflows(runtime_url, limit=limit)
    if not workflows:
        print("(no workflows)")
        return

    print(f"{'ID':<20} {'STATUS':<10} ISSUE")
    print("-" * 72)
    for workflow in workflows:
        workflow_id = str(workflow.get("workflowId") or "?")
        status = str(workflow.get("status") or "UNKNOWN")
        issue = str(workflow.get("issue") or "").strip()
        if len(issue) > 38:
            issue = issue[:35] + "..."
        print(f"{workflow_id:<20} {status:<10} {issue}")


def interactive_workflow_status(project_root: pathlib.Path, runtime_url: str) -> None:
