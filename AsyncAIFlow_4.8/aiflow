def cmd_interactive(_args: argparse.Namespace) -> int:
    project_root = require_initialized_root()

    while True:
        config = load_config(project_root)
        runtime_url = runtime_url_from_config(config)

        print()
        print("+---------------------------------------------+")
        print("|                  AsyncAIFlow                |")
        print("|          AI Workflow Terminal Console       |")
        print("+---------------------------------------------+")
        print(f"Workspace: {project_root.name}")
        print(f"Server:    {runtime_url}")
        print()
        print("[1] New Issue")
        print("[2] Recent Workflows")
        print("[3] Workflow Status")
        print("[4] Workflow Summary")
        print("[5] Action Detail")
        print("[6] Run Plan File")
        print("[7] Settings")
        print("[0] Exit")

        choice = prompt_input("Select > ")
        if choice is None:
            print()
            return 0

        normalized = choice.strip()
        try:
            if normalized == "1":
                interactive_new_issue(project_root, runtime_url)
            elif normalized == "2":
                interactive_recent_workflows(runtime_url)
            elif normalized == "3":
                interactive_workflow_status(project_root, runtime_url)
            elif normalized == "4":
                interactive_workflow_summary(project_root, runtime_url)
            elif normalized == "5":
                interactive_action_detail(runtime_url)
            elif normalized == "6":
                interactive_run_plan_file(project_root, runtime_url)
            elif normalized == "7":
                interactive_settings(project_root)
            elif normalized == "0":
                print("Bye")
                return 0
            else:
                print("Unknown menu option")
        except CliError as exc:
            print(f"aiflow: {exc}")


def cmd_status(args: argparse.Namespace) -> int:
    project_root = require_initialized_root()
    config = load_config(project_root)
    runtime_url = runtime_url_from_config(config)

    workflow_id = resolve_workflow_id(project_root, runtime_url, args.workflow_id)
    if workflow_id is None:
        raise CliError("No workflow id provided, no .aiflow/last-run.json found, and runtime returned no recent workflows.")

    workflow_execution = fetch_workflow_execution(runtime_url, workflow_id)
    workflow_actions = fetch_workflow_actions(runtime_url, workflow_id)

    if args.json:
        print(
            json.dumps(
                {
                    "workflow": workflow_execution,
                    "actions": workflow_actions,
                },
                ensure_ascii=False,
                indent=2,
            )
        )
        return 0

    print(f"Workflow {workflow_id}")
    print(f"Status: {str(workflow_execution.get('status') or 'UNKNOWN').upper()}")
    print()
    if not workflow_actions:
        print("(no actions)")
        return 0

    completed_count, total_count = workflow_progress(workflow_actions)
    print(f"Progress {completed_count}/{total_count}")
    print()

    print_workflow_action_lines(workflow_actions, marker=action_status_icon)
    return 0


def cmd_summary(args: argparse.Namespace) -> int:
    project_root = require_initialized_root()
    config = load_config(project_root)
    runtime_url = runtime_url_from_config(config)

    workflow_id = resolve_workflow_id(project_root, runtime_url, args.workflow_id)
    if workflow_id is None:
