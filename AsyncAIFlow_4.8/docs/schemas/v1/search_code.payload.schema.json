{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://asyncaiflow.dev/schemas/v1/search_code.payload.schema.json",
  "title": "search_code payload v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "query"
  ],
  "properties": {
    "schemaVersion": {
      "const": "v1"
    },
    "query": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "languages": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "includeTests": {
          "type": "boolean"
        },
        "maxResults": {
          "type": "integer",
          "minimum": 1,
          "maximum": 200
        }
      }
    },
    "hints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "symbols": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
